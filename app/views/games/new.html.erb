<div class="container">
  <div class="title">
    <h2>New game</h2>
  </div>
  <div>
    <ul class="letters">
      <% @letters.each do |letter| %>
        <li class="letters-box"><%= letter.capitalize %></li>
      <% end %>
    </ul>
  </div>

  <div class="form-words">
    <form action="/score" method="POST" data-turbo="false">
    <!-- ... -->
    <label for="input-word" class="form-label">What is the longest word you can find?</label>
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <%= hidden_field_tag :letters, @letters %>

    <div class="input-group">
      <input type="text" name="word" id="input-word" class="form-control">
      <input type="submit" value="Play" class="btn btn-primary>"
    </div>

    </form>
  </div>
</div>ˇ
